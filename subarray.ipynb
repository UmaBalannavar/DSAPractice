   "source": [
    "def fun(arr,k):\n",
    "    n=len(arr)\n",
    "    maxelem=max(arr[:k])\n",
    "    maxe=maxelem\n",
    "    for i in range(2,n):\n",
    "        maxelem=max(maxe,arr[i])\n",
    "        print(maxelem is maxe)\n",
    "\n",
    "if __name__==\"__main__\":\n",
    "    arr=[1,2,3,1,4,5]\n",
    "    k=3\n",
    "    soln=fun(arr,k)\n",
    "    #print(soln)    "
   ]
  }
